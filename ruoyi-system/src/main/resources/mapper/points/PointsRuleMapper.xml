<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.points.mapper.PointsRuleMapper">

    <resultMap id="PointsRuleResult" type="com.ruoyi.points.domain.PointsRule">
        <id     property="ruleId"       column="rule_id"/>
        <result property="ruleCode"     column="rule_code"/>
        <result property="ruleName"     column="rule_name"/>
        <result property="ruleType"     column="rule_type"/>
        <result property="rewardPoints" column="reward_points"/>
        <result property="dailyLimit"   column="daily_limit"/>
        <result property="configJson"   column="config_json"/>
        <result property="status"       column="status"/>
        <result property="createBy"     column="create_by"/>
        <result property="createTime"   column="create_time"/>
        <result property="updateBy"     column="update_by"/>
        <result property="updateTime"   column="update_time"/>
        <result property="remark"       column="remark"/>
    </resultMap>

    <sql id="ruleVo">
        select rule_id, rule_code, rule_name, rule_type, reward_points, daily_limit, config_json,
               status, create_by, create_time, update_by, update_time, remark
        from t_points_rule
    </sql>

    <select id="selectRuleList" parameterType="com.ruoyi.points.domain.PointsRule" resultMap="PointsRuleResult">
        <include refid="ruleVo"/>
        <where>
            <if test="ruleCode != null and ruleCode != ''">and rule_code like concat('%', #{ruleCode}, '%')</if>
            <if test="ruleName != null and ruleName != ''">and rule_name like concat('%', #{ruleName}, '%')</if>
            <if test="ruleType != null and ruleType != ''">and rule_type = #{ruleType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by rule_id desc
    </select>

    <select id="selectRuleById" parameterType="Long" resultMap="PointsRuleResult">
        <include refid="ruleVo"/> where rule_id=#{ruleId}
    </select>

    <select id="selectRuleByCode" parameterType="String" resultMap="PointsRuleResult">
        <include refid="ruleVo"/> where rule_code=#{ruleCode}
    </select>

    <insert id="insertRule" parameterType="com.ruoyi.points.domain.PointsRule" useGeneratedKeys="true" keyProperty="ruleId">
        insert into t_points_rule(rule_code, rule_name, rule_type, reward_points, daily_limit, config_json,
                                  status, create_by, create_time, remark)
        values(#{ruleCode}, #{ruleName}, #{ruleType}, #{rewardPoints}, #{dailyLimit}, #{configJson},
               coalesce(#{status},'0'), #{createBy}, sysdate(), #{remark})
    </insert>

    <update id="updateRule" parameterType="com.ruoyi.points.domain.PointsRule">
        update t_points_rule
        <set>
            <if test="ruleName != null">rule_name=#{ruleName},</if>
            <if test="ruleType != null">rule_type=#{ruleType},</if>
            <if test="rewardPoints != null">reward_points=#{rewardPoints},</if>
            <if test="dailyLimit != null">daily_limit=#{dailyLimit},</if>
            <if test="configJson != null">config_json=#{configJson},</if>
            <if test="status != null">status=#{status},</if>
            <if test="updateBy != null">update_by=#{updateBy},</if>
            <if test="remark != null">remark=#{remark},</if>
            update_time = sysdate()
        </set>
        where rule_id=#{ruleId}
    </update>

    <delete id="deleteRuleByIds">
        delete from t_points_rule where rule_id in
        <foreach collection="array" item="id" open="(" close=")" separator=",">#{id}</foreach>
    </delete>

</mapper>
