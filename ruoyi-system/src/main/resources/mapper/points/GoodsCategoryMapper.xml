<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.points.mapper.GoodsCategoryMapper">

    <resultMap id="GoodsCategoryResult" type="com.ruoyi.points.domain.GoodsCategory">
        <id     property="categoryId"   column="category_id"/>
        <result property="parentId"     column="parent_id"/>
        <result property="ancestors"    column="ancestors"/>
        <result property="categoryName" column="category_name"/>
        <result property="orderNum"     column="order_num"/>
        <result property="icon"         column="icon"/>
        <result property="status"       column="status"/>
        <result property="delFlag"      column="del_flag"/>
        <result property="createBy"     column="create_by"/>
        <result property="createTime"   column="create_time"/>
        <result property="updateBy"     column="update_by"/>
        <result property="updateTime"   column="update_time"/>
        <result property="remark"       column="remark"/>
    </resultMap>

    <sql id="selectCategoryVo">
        select category_id, parent_id, ancestors, category_name, order_num, icon, status, del_flag,
               create_by, create_time, update_by, update_time, remark
        from t_goods_category
    </sql>

    <select id="selectCategoryList" parameterType="com.ruoyi.points.domain.GoodsCategory" resultMap="GoodsCategoryResult">
        <include refid="selectCategoryVo"/>
        <where>
            del_flag = '0'
            <if test="categoryName != null and categoryName != ''">
                and category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by parent_id, order_num
    </select>

    <select id="selectCategoryById" parameterType="Long" resultMap="GoodsCategoryResult">
        <include refid="selectCategoryVo"/>
        where category_id = #{categoryId} and del_flag = '0'
    </select>

    <insert id="insertCategory" parameterType="com.ruoyi.points.domain.GoodsCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into t_goods_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="parentId != null">parent_id,</if>
            <if test="ancestors != null">ancestors,</if>
            <if test="categoryName != null">category_name,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="icon != null">icon,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="parentId != null">#{parentId},</if>
            <if test="ancestors != null">#{ancestors},</if>
            <if test="categoryName != null">#{categoryName},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="icon != null">#{icon},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateCategory" parameterType="com.ruoyi.points.domain.GoodsCategory">
        update t_goods_category
        <set>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="ancestors != null">ancestors = #{ancestors},</if>
            <if test="categoryName != null">category_name = #{categoryName},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <update id="deleteCategoryById" parameterType="Long">
        update t_goods_category set del_flag='2' where category_id=#{categoryId}
    </update>

    <select id="hasChildByCategoryId" resultType="Integer" parameterType="Long">
        select count(1) from t_goods_category where parent_id=#{categoryId} and del_flag='0'
    </select>

    <select id="checkCategoryUseInGoods" resultType="Integer" parameterType="Long">
        select count(1) from t_goods where category_id=#{categoryId} and del_flag='0'
    </select>

</mapper>
